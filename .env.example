# MongoDB (default: mongodb://127.0.0.1:27017/setupai)
MONGODB_URI=mongodb://127.0.0.1:27017/setupai

# NextAuth – required (middleware reads these from env only)
# Dev: use the value below; production: use e.g. openssl rand -base64 32
NEXTAUTH_SECRET=setupai-dev-secret-min-32-chars-for-jwt-signing
NEXTAUTH_URL=http://localhost:3000
