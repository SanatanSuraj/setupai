# MongoDB (default: mongodb://127.0.0.1:27017/setupai)
MONGODB_URI=mongodb://127.0.0.1:27017/setupai

# NextAuth – required (middleware reads these from env only)
# Dev: use the value below; production: use e.g. openssl rand -base64 32
NEXTAUTH_SECRET=setupai-dev-secret-min-32-chars-for-jwt-signing
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — required for "Continue with Google" (see lib/auth-options.ts)
# In Google Cloud Console → Credentials → OAuth 2.0 Client:
#   Authorized JavaScript origins: http://localhost:3000  (and your production URL)
#   Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NodeMailer / SMTP Config
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="SetupAI <noreply@example.com>"